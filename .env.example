AGENTIC_LAB_DATABASE_URL=postgresql+psycopg://agentic_lab:agentic_lab@postgres:5432/agentic_lab
AGENTIC_LAB_OPERATOR_TOKEN=replace-with-a-local-random-token
AGENTIC_LAB_GITHUB_WEBHOOK_SECRET=replace-with-a-local-webhook-secret
AGENTIC_LAB_ALLOWED_REPOSITORY_IDS=[123456]
AGENTIC_LAB_ENVIRONMENT=local
AGENTIC_LAB_MAX_MODEL_TURNS=12
AGENTIC_LAB_MAX_TOOL_CALLS=40
AGENTIC_LAB_MAX_WALL_SECONDS=1200
AGENTIC_LAB_MAX_USD=3.00
AGENTIC_LAB_REQUIRE_TARGET_MANIFEST=true
AGENTIC_LAB_OPENROUTER_API_KEY=replace-with-a-local-openrouter-key
AGENTIC_LAB_ALLOWED_MODEL_IDS=["provider/model@pinned-version"]
AGENTIC_LAB_ALLOWED_PROVIDER_IDS=["provider"]
AGENTIC_LAB_GITHUB_APP_ID=123456
AGENTIC_LAB_GITHUB_PRIVATE_KEY=replace-with-a-local-private-key
AGENTIC_LAB_GITHUB_API_URL=https://api.github.com
AGENTIC_LAB_LANGFUSE_PUBLIC_KEY=replace-with-a-local-public-key
AGENTIC_LAB_LANGFUSE_SECRET_KEY=replace-with-a-local-secret-key
AGENTIC_LAB_LANGFUSE_HOST=https://cloud.langfuse.com
AGENTIC_LAB_EXECUTOR_IMAGE_DIGEST=registry/image@sha256:replace-with-64-hex-characters
AGENTIC_LAB_EXECUTOR_TRANSPORT_ROOT=/tmp/agentic-lab-executor
AGENTIC_LAB_EXECUTOR_HOST_TRANSPORT_ROOT=/tmp/agentic-lab-executor
